# ============================================
# GovTrust AI — AI Gateway env (copy thành .env)
# ============================================

# --- App ---
AI_GATEWAY_PORT=8000

# --- Qdrant (Vector DB cho LawGuard) ---
# Dùng QDRANT_URL nếu có; nếu trống sẽ fallback về host/port.
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Để trống nếu Qdrant chạy local không bật API key.
QDRANT_API_KEY=

# --- Embedding model (phải ra đúng 768 chiều để khớp collection) ---
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
EMBEDDING_DEVICE=cpu

# --- RAG retrieval ---
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5
