{
  "name": "@govtrust/core-svc",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "test": "jest",
    "test:integration": "RUN_RECONCILER_INTEGRATION=true jest --runInBand src/queue/job-reconciler.integration.spec.ts",
