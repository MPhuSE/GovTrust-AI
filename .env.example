# ============================================
# GovTrust AI — Environment Variables
# ============================================
# Copy file này thành .env và điền giá trị thật

# --- General ---
NODE_ENV=development
APP_PORT=3000
API_PORT=4000
AI_SVC_PORT=8000

# --- gRPC ports (inter-service) ---
AI_SVC_GRPC_URL=localhost:50051
INSIGHTS_SVC_GRPC_URL=localhost:50052
INSIGHTS_GRPC_PORT=50052

# --- MongoDB (core-svc) ---
MONGO_URI=mongodb://localhost:27017/govtrust_core
MONGO_DB_NAME=govtrust_core

# --- MongoDB (insights-svc — DB riêng) ---
INSIGHTS_MONGO_URI=mongodb://localhost:27017/govtrust_analytics

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- JWT Auth ---
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=24h

# --- VNPT eKYC (BẮT BUỘC — do BTC cung cấp) ---
VNPT_EKYC_BASE_URL=https://api.vnpt-ekyc.vn
VNPT_EKYC_TOKEN_ID=your-token-id
VNPT_EKYC_TOKEN_KEY=your-token-key
VNPT_EKYC_ACCESS_TOKEN=your-access-token

# --- VNPT SmartReader ---
VNPT_SMARTREADER_BASE_URL=https://api.smartreader.vnpt.vn
VNPT_SMARTREADER_API_KEY=your-api-key

# --- VNPT SmartBot ---
VNPT_SMARTBOT_BASE_URL=https://api.smartbot.vnpt.vn
VNPT_SMARTBOT_API_KEY=your-api-key

# --- VNPT SmartVoice ---
VNPT_SMARTVOICE_BASE_URL=https://api.smartvoice.vnpt.vn
VNPT_SMARTVOICE_API_KEY=your-api-key

# --- VNPT SmartUX ---
VNPT_SMARTUX_BASE_URL=https://api.smartux.vnpt.vn
VNPT_SMARTUX_API_KEY=your-api-key

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=legal_chunks
QDRANT_VECTOR_SIZE=768

# --- File Storage ---
UPLOAD_DIR=./uploads
FILE_TTL_MINUTES=30
MAX_FILE_SIZE_MB=10

# --- Session ---
SESSION_TTL_HOURS=24

# --- AI Gateway URL (dùng trong NestJS) ---
AI_GATEWAY_URL=http://localhost:8000

# --- Next.js Public ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=GovTrust AI
