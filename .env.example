# ============================================
# GovTrust AI — Environment Variables
# Copy thành .env (hoặc để scripts/quickstart.sh tự sinh). Kiến trúc 4 service.
# Các secret (JWT RSA, PII key) sẽ được quickstart.sh tự sinh nếu còn giá trị "AUTO_GENERATE".
# ============================================

# --- General ---
NODE_ENV=development

# --- api-gateway (cổng public DUY NHẤT) ---
GATEWAY_PORT=8080
CORE_SVC_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000

# --- core-svc ---
API_PORT=4000
# Local (docker-compose tự override thành mongo container). Đổi thành Atlas URI nếu chạy cloud.
MONGO_URI=mongodb://localhost:27017/govtrust_business
MONGO_DB_NAME=govtrust_business

# --- ai-svc (FastAPI REST + Python gRPC) ---
AI_SVC_PORT=8000
AI_SVC_GRPC_URL=localhost:50051     # core-svc dùng để gọi; ai-svc bind 0.0.0.0:50051

# --- Redis (BullMQ + cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Mã hóa PII (AES-256-GCM). quickstart.sh tự sinh 32-byte base64. ---
# Sinh tay: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_ENCRYPTION_KEY=AUTO_GENERATE

# --- JWT Auth — RS256 keypair (core-svc ký bằng private, gateway verify bằng public) ---
# quickstart.sh tự sinh cặp key. Sinh tay:
#   openssl genrsa -out /tmp/jwt.key 2048
#   openssl rsa -in /tmp/jwt.key -pubout -out /tmp/jwt.pub
# rồi dán vào (giữ trong ngoặc kép, xuống dòng thật):
JWT_ACCESS_PRIVATE_KEY="AUTO_GENERATE"
JWT_ACCESS_PUBLIC_KEY="AUTO_GENERATE"
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_DAYS=7

# --- OCR: dùng API thật (KHÔNG mock). Cần điền token VNPT + Qwen bên dưới. ---
MOCK_OCR_FOR_DEMO=false

# --- VNPT — bắt buộc để OCR giấy tờ tùy thân / hành chính ---
VNPT_BASE_URL=https://api.idg.vnpt.vn
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
VNPT_EKYC_ACCESS_TOKEN=
VNPT_SMARTREADER_TOKEN_ID=
VNPT_SMARTREADER_TOKEN_KEY=
VNPT_SMARTREADER_ACCESS_TOKEN=
VNPT_SMARTBOT_BASE_URL=https://assistant-stream.vnpt.vn
VNPT_SMARTBOT_TOKEN_ID=
VNPT_SMARTBOT_TOKEN_KEY=
VNPT_SMARTBOT_ACCESS_TOKEN=
VNPT_SMARTBOT_BOT_ID=
VNPT_SMARTVOICE_TOKEN_ID=
VNPT_SMARTVOICE_TOKEN_KEY=
VNPT_SMARTVOICE_ACCESS_TOKEN=

# --- Qwen VL OCR (giấy tờ Qwen đọc: chứng sinh, sổ đỏ, hợp đồng). BẮT BUỘC. ---
QWEN_OCR_API_KEY=
QWEN_OCR_BASE_URL=https://api.shopaikey.com/v1

# --- Vector DB (Qdrant — ai-svc sở hữu; LawGuard RAG). ---
# docker-compose mặc định trỏ Qdrant remote đã seed 875 chunk (cần QDRANT_API_KEY).
# Để trống + LawGuard sẽ báo "chưa cấu hình" chứ không sập app.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_chunks
QDRANT_VECTOR_SIZE=768
QDRANT_VECTOR_NAME=dense
QDRANT_INGEST_ON_STARTUP=false
LEGAL_CHUNKS_DIR=./data/legal-sources/chunks

# --- Embedding cho hybrid RAG ---
# local: cài requirements-local.txt + SentenceTransformer (tải model ~500MB lần đầu).
# api : endpoint tương thích OpenAI, dùng EMBEDDING_API_KEY.
EMBEDDING_PROVIDER=local
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
EMBEDDING_DIMENSIONS=768

# Optional: LLM tương thích OpenAI để /api/v1/lawguard/ask sinh câu trả lời có nguồn.
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=

# --- File Storage ---
UPLOAD_DIR=./uploads
SEED_MVP_PROCEDURES=true
FILE_TTL_MINUTES=30
MAX_FILE_SIZE_MB=10

# --- Session ---
SESSION_TTL_HOURS=24

# Bật endpoint [DEV ONLY] POST /sessions/mock (tiêm OCR data giả để test cross-check).
ENABLE_MOCK_SESSIONS=

# --- Mongo outbox reconciler (milliseconds) ---
JOB_RECONCILER_INTERVAL_MS=30000
JOB_PENDING_TIMEOUT_MS=30000
JOB_PROCESSING_TIMEOUT_MS=300000
JOB_MAX_ATTEMPTS=3
JOB_RECONCILER_BATCH_SIZE=100

# --- Next.js Public (trỏ tới api-gateway) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=GovTrust AI
