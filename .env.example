# ============================================
# GovTrust AI — Environment Variables
# Copy thành .env. Kiến trúc 4 service (xem docs/ARCHITECTURE.md).
# ============================================

# --- General ---
NODE_ENV=development

# --- api-gateway (cổng public DUY NHẤT) ---
GATEWAY_PORT=8080
CORE_SVC_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000

# --- core-svc ---
API_PORT=4000
MONGO_URI=mongodb://localhost:27017/govtrust_business
MONGO_DB_NAME=govtrust_business

# --- ai-svc (FastAPI REST + Python gRPC) ---
AI_SVC_PORT=8000
AI_SVC_GRPC_URL=localhost:50051     # core-svc dùng để gọi; ai-svc bind 0.0.0.0:50051

# --- Redis (BullMQ + cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT Auth (core-svc cấp, api-gateway verify — CHUNG secret) ---
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=24h

# --- VNPT — Domain chung cho mọi dịch vụ (eKYC, SmartReader, SmartBot, SmartVoice) ---
VNPT_BASE_URL=https://api.idg.vnpt.vn

# eKYC: OCR giấy tờ tùy thân CCCD/CMND — path WEB /ai/v1/web/ocr/id. Trống = mock.
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
VNPT_EKYC_ACCESS_TOKEN=

# SmartReader: bóc tách văn bản hành chính. Trống = mock.
VNPT_SMARTREADER_TOKEN_ID=
VNPT_SMARTREADER_TOKEN_KEY=
VNPT_SMARTREADER_ACCESS_TOKEN=

# SmartBot streaming — bot ID lấy từ bot đã tạo trên VNPT SmartBot Platform.
VNPT_SMARTBOT_BASE_URL=https://assistant-stream.vnpt.vn
VNPT_SMARTBOT_TOKEN_ID=
VNPT_SMARTBOT_TOKEN_KEY=
VNPT_SMARTBOT_ACCESS_TOKEN=
VNPT_SMARTBOT_BOT_ID=

# SmartVoice
VNPT_SMARTVOICE_API_KEY=

# --- Vector DB (Qdrant — ai-svc sở hữu) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=legal_chunks
QDRANT_VECTOR_SIZE=768
QDRANT_VECTOR_NAME=dense
QDRANT_INGEST_ON_STARTUP=false
LEGAL_CHUNKS_DIR=./data/legal-sources/chunks

# --- Embedding cho hybrid RAG ---
# api (mặc định): endpoint tương thích OpenAI, dùng API key.
# local: cài requirements-local.txt và chọn model SentenceTransformer.
# Vector size PHẢI khớp output; dimensions=768 giữ tương thích collection hiện tại.
EMBEDDING_PROVIDER=local
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
EMBEDDING_DIMENSIONS=768

# Optional: LLM tương thích OpenAI để /api/v1/lawguard/ask sinh câu trả lời có nguồn.
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=

# --- File Storage ---
UPLOAD_DIR=./uploads
SEED_MVP_PROCEDURES=true
FILE_TTL_MINUTES=30
MAX_FILE_SIZE_MB=10

# --- Session ---
SESSION_TTL_HOURS=24

# --- Mongo outbox reconciler (milliseconds) ---
JOB_RECONCILER_INTERVAL_MS=30000
JOB_PENDING_TIMEOUT_MS=30000
JOB_PROCESSING_TIMEOUT_MS=300000
JOB_MAX_ATTEMPTS=3
JOB_RECONCILER_BATCH_SIZE=100

# --- Next.js Public (trỏ tới api-gateway) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=GovTrust AI
